# FixIt Buddy — Environment Variables
# Copy to .env and fill in values

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=fixitbuddy

# Use Vertex AI (TRUE for production on Cloud Run, FALSE for dev with API key)
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Only needed if GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=

# Agent configuration
# For live streaming (production): gemini-2.5-flash-native-audio-preview-12-2025
# For text testing (dev): gemini-2.5-flash
AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
AGENT_VOICE=Aoede
