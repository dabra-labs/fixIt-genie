graph TB
    subgraph "Android App (Kotlin + Jetpack Compose)"
        UI[SessionScreen<br/>Material 3 UI]
        VM[SessionViewModel<br/>Hilt DI]
        CAM[CameraManager<br/>CameraX 1 FPS JPEG]
        AUD[AudioStreamManager<br/>16kHz PCM in / 24kHz out]
        WS[AgentWebSocket<br/>OkHttp — ADK LiveRequest protocol]
    end

    subgraph "Google Cloud Run"
        CR[ADK Web Server<br/>adk web — bidi-streaming]

        subgraph "Agent Tools (Function Calling)"
            KB[lookup_equipment_knowledge<br/>7 docs · 33 error codes]
            SW[get_safety_warnings<br/>6 hazard categories]
            LOG[log_diagnostic_step<br/>Session transcript]
        end

        KNOWLEDGEBASE[(Embedded Knowledge Base<br/>Automotive · Electrical · Appliance)]
    end

    GEMINI[Gemini 2.5 Flash<br/>Native Audio Preview<br/>bidiGenerateContent]

    UI --> VM
    VM --> CAM
    VM --> AUD
    VM --> WS

    WS -- "Audio: Base64 PCM 16kHz<br/>LiveRequest blobs" --> CR
    CR -- "Audio: Base64 PCM 24kHz<br/>Transcripts · Status<br/>LiveEvent content" --> WS

    CR -- "bidiGenerateContent<br/>+ Function Calling" --> GEMINI
    GEMINI -- "Text + Audio + Tool Calls" --> CR

    CR --> KB
    CR --> SW
    CR --> LOG

    KB --> KNOWLEDGEBASE

    classDef android fill:#E65100,color:#fff,stroke:#BF360C
    classDef gcloud fill:#1565C0,color:#fff,stroke:#0D47A1
    classDef gemini fill:#7B1FA2,color:#fff,stroke:#4A148C
    classDef knowledge fill:#2E7D32,color:#fff,stroke:#1B5E20

    class UI,VM,CAM,AUD,WS android
    class CR,KB,SW,LOG gcloud
    class GEMINI gemini
    class KNOWLEDGEBASE knowledge
