# FixIt Genie — Root .gitignore

# ─── OS ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ─── IDE / Editor ────────────────────────────────────────
.idea/
*.iml
.vscode/
.fleet/
*.code-workspace

# ─── Python ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Environment & Secrets ───────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.keystore
*.jks
service-account*.json
credentials*.json
google-services.json

# ─── Android ─────────────────────────────────────────────
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/captures/
android/gradle/wrap-aapt2.gradle
*.apk
*.aab
*.hprof

# ─── Backend / ADK ───────────────────────────────────────
backend/fixitbuddy/.adk/

# ─── Dev / Internal ──────────────────────────────────────
CLAUDE.md
MEMORY.md
HANDOFF.md
PROGRESS.md
.claude/
.superpowers/brainstorm/
.internal-docs/
.playwright-mcp/
recordings/

# ─── Misc ────────────────────────────────────────────────
*.log
*.tmp
*.pdf
